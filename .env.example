# Copy this file to `.env` in the project root and replace the placeholders.
# Dashboard & docs: https://api-ninjas.com — Quotes API: https://api-ninjas.com/api/quotes
#
# Use the API hostname (where HTTP requests go), not the marketing site:
API_NINJAS_BASE_URL=https://api.api-ninjas.com
API_NINJAS_KEY=your_api_ninjas_key_here
